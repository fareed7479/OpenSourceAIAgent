# Project Configurations
API_V1_STR=/api/v1
PROJECT_NAME="Open Source AI Contribution Agent"

# Security (Change in production!)
# ENCRYPTION_KEY must be a valid Fernet key (32 url-safe base64-encoded bytes)
SECRET_KEY=supersecretjwtkey_change_me_in_production_1234567890
ENCRYPTION_KEY=
DATABASE_URL=sqlite:///./agent_platform.db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# GitHub OAuth settings
# Leaving client ID blank triggers the developer mock login bypass in the API.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback

# Workspace management
WORKSPACES_DIR=./workspaces

# LLM Providers Configuration
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub Webhook Secret
GITHUB_WEBHOOK_SECRET=supersecretwebhookkey
